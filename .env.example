# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/k9overwatch.db
# For production PostgreSQL + PostGIS:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/k9overwatch

# ── Search center (defaults to Indianapolis downtown) ───────────────────────
SEARCH_LAT=39.7684
SEARCH_LON=-86.1581
SEARCH_RADIUS_MILES=25

# ── Geocoding ────────────────────────────────────────────────────────────────
GEOCODE_PROVIDER=nominatim          # nominatim | google
GOOGLE_MAPS_API_KEY=                # required if GEOCODE_PROVIDER=google
NOMINATIM_USER_AGENT=k9overwatch/1.0 (your@email.com)

# ── Rate limiting ─────────────────────────────────────────────────────────────
HTTP_RATE_LIMIT_SECONDS=1.5
PLAYWRIGHT_HEADLESS=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=pretty                   # pretty | json
